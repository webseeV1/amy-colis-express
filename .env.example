# ============================================================
# AMY COLIS EXPRESS — Variables d'environnement (EXEMPLE)
# Copiez ce fichier en .env.local (dev) ou configurez-les
# dans Vercel (Project Settings > Environment Variables).
# NE COMMITEZ JAMAIS vos vraies valeurs.
# ============================================================

# --- Base de données PostgreSQL / Supabase -----------------
# DATABASE_URL : connexion utilisée par l'application (poolée en prod).
# Sur Supabase, utilisez le "Connection Pooler" (port 6543, ?pgbouncer=true).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL : connexion DIRECTE (port 5432), utilisée pour les migrations
# Prisma (prisma migrate deploy/dev). Indispensable avec un pooler.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Supabase (côté client / service) ----------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# --- Authentification (JWT maison) -------------------------
# Secret de signature des sessions JWT. Générez une valeur forte :
#   openssl rand -base64 32
JWT_SECRET="CHANGEZ_MOI_secret_jwt_long_et_aleatoire"

# PIN administrateur maître (déverrouille tous les comptes admin).
ADMIN_PIN="020106"

# --- Application -------------------------------------------
NEXT_PUBLIC_APP_URL="https://votre-domaine.vercel.app"

# --- IA Gemini (optionnel) ---------------------------------
# La clé Gemini se configure normalement dans l'app (Paramètres).
# Vous pouvez aussi la fournir ici comme valeur par défaut.
GEMINI_API_KEY=""
